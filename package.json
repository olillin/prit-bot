        "drizzle-orm": "^0.45.2",
        "iamcal": "^4.1.0",
        "pg": "^8.22.0",
        "rollup": "^4.59.0",
        "typescript": "^5.8.3"
    },
    "devDependencies": {
        "@types/node": "^24.13.2",
        "@types/pg": "^8.20.0",
        "copy-env-cli": "^1.0.0",
        "drizzle-kit": "^0.31.10",
        "globals": "^16.0.0",
        "oxfmt": "^0.41.0",
        "oxlint": "^1.56.0",
        "oxlint-tsgolint": "^0.17.0",
        "rolldown": "1.0.0-rc.9"
