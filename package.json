{
    "name": "prit-bot",
    "version": "1.14.2",
    "description": "Discord bot for P.R.I.T.",
    "homepage": "https://github.com/olillin/prit-bot#readme",
    "bugs": {
        "url": "https://github.com/olillin/prit-bot/issues"
    },
    "license": "MIT",
    "author": "Olillin <oli@olillin.com>",
    "repository": {
        "type": "git",
        "url": "git+https://github.com/olillin/prit-bot.git"
    },
    "type": "module",
    "main": "bundle/main.js",
    "scripts": {
        "build": "tsc && rolldown -c",
        "start": "node .",
        "startenv": "node --env-file=.env .",
